---
// Schema.org - eine Physiotherapie-Praxis + Gründer Hartmut Meyer.
// Nur belegte Fakten (Scrape/Impressum). 4,9-Rating ist über die Google-Place-ID
// verifiziert (Altseite), daher als aggregateRating ausgewiesen.
import { site } from '../data/site';
interface Props { schema?: object | object[] | null }
const { schema = null } = Astro.props;

const person = {
  '@type': 'Person',
  '@id': site.url + '/#hartmut',
  name: 'Hartmut Meyer',
  jobTitle: 'Physiotherapeut · Osteopathie',
  worksFor: { '@id': site.url + '/#praxis' },
};

const place = {
  '@type': 'Physiotherapy',
  '@id': site.url + '/#praxis',
  name: site.name,
  legalName: site.legalName,
  description: site.description,
  url: site.url,
  telephone: site.phoneIntl,
  faxNumber: '+49891781476',
  email: site.email,
  image: new URL('/images/og-image.jpg', site.url).toString(),
  logo: new URL('/logo.png', site.url).toString(),
  founder: { '@id': site.url + '/#hartmut' },
  sameAs: [site.instagram],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.street,
    postalCode: site.postcode,
    addressLocality: 'München',
    addressRegion: 'Bayern',
    addressCountry: 'DE',
  },
  areaServed: ['München', 'Nymphenburg', 'München-West'],
  medicalSpecialty: ['Physiotherapy', 'SportsMedicine'],
  availableService: [
    'Physiotherapie', 'Osteopathie', 'Ganzheitliche Therapie',
    'Krankengymnastik', 'Krankengymnastik am Gerät (KGG)', 'Manuelle Therapie',
    'Manuelle Lymphdrainage', 'CMD / Craniomandibuläre Dysfunktion',
    'Massage', 'Elektrotherapie', 'Wärmetherapie',
  ],
  // 4,9 wird visuell als Badge gezeigt (Google-Place-ID); ohne dokumentierte
  // ratingCount kein aggregateRating im Schema (sonst unvollständig/invalide).
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'], opens: '08:00', closes: '19:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '08:00', closes: '13:00' },
  ],
};

const extra = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const json = JSON.stringify({ '@context': 'https://schema.org', '@graph': [person, place, ...extra] });
---
<script type="application/ld+json" set:html={json} />
