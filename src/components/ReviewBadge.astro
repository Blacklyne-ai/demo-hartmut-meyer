---
// Google-Reputations-Badge - zeigt NUR die belegte 4,9 (Place-ID verifiziert).
// Kein erfundener Bewertungstext, keine erfundene Anzahl. Sterne rein visuell.
import { site } from '../data/site';
interface Props { align?: 'left' | 'center'; class?: string }
const { align = 'left', class: className = '' } = Astro.props;
const rating = parseFloat(site.googleRating.replace(',', '.'));
const full = Math.floor(rating);
const hasHalf = rating - full >= 0.25;
---
<div class={`inline-flex items-center gap-4 rounded-2xl px-5 py-3.5 ${align === 'center' ? 'mx-auto' : ''} ${className}`}
     style="background: rgb(255 255 255 / 0.7); border: 1px solid rgb(var(--rgb-border)); box-shadow: var(--shadow-soft); backdrop-filter: blur(8px);">
  <div class="text-left">
    <div class="flex items-baseline gap-1.5">
      <span class="font-display text-2xl text-ink leading-none">{site.googleRating}</span>
      <span class="text-muted-light text-sm">von 5</span>
    </div>
    <div class="flex items-center gap-0.5 mt-1" aria-hidden="true">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg width="15" height="15" viewBox="0 0 24 24" class={i < full || (i === full && hasHalf) ? 'star-on' : 'star-off'}>
          <path d="M12 2.5l2.94 5.96 6.58.96-4.76 4.64 1.12 6.55L12 18.1l-5.88 3.07 1.12-6.55L2.48 9.42l6.58-.96L12 2.5z" />
        </svg>
      ))}
    </div>
  </div>
  <span class="h-9 w-px" style="background: rgb(var(--rgb-border));"></span>
  <div class="flex items-center gap-2 text-[0.92rem] text-muted">
    <!-- Google G (inline, da Lucide keine Brand-Icons hat) -->
    <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
      <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
      <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
      <path fill="#FBBC05" d="M11.69 28.18c-.44-1.32-.69-2.73-.69-4.18s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
      <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
    </svg>
    <span>Google Bewertungen</span>
  </div>
</div>

<style>
  .star-on { fill: #F5B544; }
  .star-off { fill: rgb(var(--rgb-sand)); }
</style>
