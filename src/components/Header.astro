---
import { nav, site } from '../data/site';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;
// Desktop-Pille: Kontakt (= CTA) nicht doppelt als Textlink
const navLinks = nav.filter((i) => i.href !== '/kontakt');

const isActive = (item: (typeof nav)[number]) =>
  current === item.href ||
  (item.href.length > 1 && current.startsWith(item.href)) ||
  (!!item.children && item.children.some((c) => c.href === current));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">
  <!-- Recruiting-Bar (oben, prominent - Schwerpunkt Mitarbeitergewinnung) -->
  <a href="/karriere" id="hiring-bar" class="group block text-white relative" style="background: linear-gradient(90deg, rgb(var(--rgb-dark)) 0%, rgb(var(--rgb-blue-deep)) 50%, rgb(var(--rgb-dark)) 100%);">
    <div class="container-wide py-[0.45rem] flex items-center justify-center gap-3 text-center">
      <span class="dot dot-green flex-shrink-0"></span>
      <span class="text-[0.76rem] md:text-[0.8rem] tracking-[0.005em] text-white/75">
        <span class="hidden sm:inline">Wir suchen Verstärkung — </span><span class="font-semibold text-white">im Team Meyer arbeiten</span>
      </span>
      <span class="inline-flex items-center gap-1 text-[0.76rem] md:text-[0.8rem] font-semibold text-blue-bright">
        Jetzt bewerben<Icon name="ArrowRight" size={13} strokeWidth={2.4} class="transition-transform group-hover:translate-x-1" />
      </span>
    </div>
  </a>
  <div class="container-wide pt-2.5 md:pt-3">
    <div
      id="nav-pill"
      class="flex items-center justify-between gap-4 rounded-pill pl-5 pr-2 md:pl-7 md:pr-3 h-14 md:h-[3.9rem] transition-all duration-300"
      style="background: rgba(250,249,246,0.68); backdrop-filter: blur(22px) saturate(180%); -webkit-backdrop-filter: blur(22px) saturate(180%); border: 1px solid rgba(255,255,255,0.6); box-shadow: 0 1px 0 rgba(255,255,255,0.55) inset, 0 10px 38px -18px rgba(8,48,63,0.3);"
    >
      <!-- Brand: Original-Logo 1:1 -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label={`${site.name} - Startseite`}>
        <img src="/logo.png" alt="Physiotherapie & Osteopathie Hartmut Meyer - München-Nymphenburg" width="220" height="38" class="h-8 md:h-10 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-x-2.5 xl:gap-x-5" aria-label="Hauptnavigation">
        {navLinks.map((item) =>
          item.children ? (
            <div class="nav-dd relative">
              <a href={item.href} class={`nav-link inline-flex items-center gap-1 ${isActive(item) ? 'active' : ''}`} aria-haspopup="true" aria-expanded="false">
                {item.label}
                <Icon name="ChevronDown" size={14} strokeWidth={2.2} class="nav-dd-chev" />
              </a>
              <div class="nav-dd-panel" role="menu">
                {item.children.map((c) => (
                  <a href={c.href} role="menuitem" class={`nav-dd-item ${current === c.href ? 'active' : ''}`}>{c.label}</a>
                ))}
              </div>
            </div>
          ) : item.highlight ? (
            <a href={item.href} aria-current={isActive(item) ? 'page' : undefined} class={`nav-jobs ${isActive(item) ? 'active' : ''}`}>
              <Icon name="Users" size={15} strokeWidth={2} />{item.label}
            </a>
          ) : (
            <a href={item.href} aria-current={isActive(item) ? 'page' : undefined} class={`nav-link ${isActive(item) ? 'active' : ''}`}>{item.label}</a>
          )
        )}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-2.5">
        <a href={`tel:${site.phoneIntl}`} class="hidden 2xl:inline-flex items-center gap-2 text-ink/80 hover:text-blue-ink transition text-sm font-medium" aria-label={`Anrufen ${site.phoneDisplay}`}>
          <Icon name="Phone" size={15} strokeWidth={2} class="text-blue-deep" />
          <span>{site.phoneDisplay}</span>
        </a>

        <!-- Google-Bewertungen (echte 4,9, Place-ID verifiziert) - wie eine Google-Widget-Pille -->
        <a href={site.reviewsUrl} target="_blank" rel="noopener noreferrer"
           class="hidden lg:inline-flex items-center gap-2 rounded-full pl-1.5 pr-3 h-10 border border-line bg-white/60 hover:bg-white hover:shadow-sm transition"
           aria-label={`${site.googleRating} von 5 Sternen bei Google - Bewertungen ansehen`}>
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-white shadow-sm flex-shrink-0">
            <svg width="15" height="15" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
              <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
              <path fill="#FBBC05" d="M11.69 28.18c-.44-1.32-.69-2.73-.69-4.18s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
              <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
            </svg>
          </span>
          <span class="flex flex-col leading-none">
            <span class="flex items-center gap-1">
              <span class="text-[0.88rem] font-bold text-ink">{site.googleRating}</span>
              <span class="flex gap-[1px]" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="11" height="11" viewBox="0 0 24 24" style="fill:#F5B544"><path d="M12 2.5l2.94 5.96 6.58.96-4.76 4.64 1.12 6.55L12 18.1l-5.88 3.07 1.12-6.55L2.48 9.42l6.58-.96L12 2.5z"/></svg>
                ))}
              </span>
            </span>
            <span class="text-[0.58rem] font-medium tracking-[0.03em] text-muted mt-[3px]">Google Bewertungen</span>
          </span>
        </a>

        <a href="/kontakt" class="btn btn-blue btn-sm hidden sm:inline-flex">Termin anfragen<Icon name="ArrowRight" size={14} strokeWidth={2.2} /></a>

        <button id="menu-toggle" class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-full transition" style="color:#08303F;" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (Pille darunter) -->
  <div id="mobile-menu" class="hidden lg:hidden container-wide mt-2">
    <nav class="rounded-3xl p-4 flex flex-col max-h-[calc(100vh-6rem)] overflow-y-auto" style="background: rgba(250,249,245,0.98); backdrop-filter: blur(18px); border: 1px solid rgba(228,223,214,0.85); box-shadow: 0 24px 50px -22px rgba(30,35,45,0.28);" aria-label="Mobile Navigation">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href}
            class="py-3 text-ink/90 hover:text-blue-ink border-b border-line/70 font-display text-lg inline-flex items-center gap-1.5"
            style={current === item.href || item.highlight ? 'color:#023E59' : ''}>
            {item.highlight && <Icon name="Users" size={17} strokeWidth={2} class="text-blue-deep" />}{item.label}
          </a>
          {item.children && (
            <div class="flex flex-col pl-4 border-b border-line/70">
              {item.children.map((c) => (
                <a href={c.href} class="py-2.5 text-[0.95rem] text-muted hover:text-blue-ink transition">{c.label}</a>
              ))}
            </div>
          )}
        </Fragment>
      ))}
      <div class="grid grid-cols-2 gap-2.5 mt-5">
        <a href={`tel:${site.phoneIntl}`} class="btn btn-outline btn-sm"><Icon name="Phone" size={15} strokeWidth={2.2} /> Anrufen</a>
        <a href="/kontakt" class="btn btn-blue btn-sm">Termin anfragen</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .hamburger { display: inline-flex; flex-direction: column; justify-content: center; gap: 5px; width: 22px; height: 22px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: #08303F; border-radius: 2px; transition: transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55), opacity 0.25s ease; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Jobs/Karriere - dezent hervorgehoben (Recruiting-Schwerpunkt) */
  .nav-jobs {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.42rem 0.85rem; border-radius: 999px;
    font-size: 0.88rem; font-weight: 600; color: rgb(var(--rgb-blue-ink));
    background: rgb(var(--rgb-blue) / 0.10); border: 1px solid rgb(var(--rgb-blue) / 0.22);
    transition: background 0.25s ease, border-color 0.25s ease, color 0.2s ease;
  }
  .nav-jobs:hover, .nav-jobs.active { background: rgb(var(--rgb-blue-deep)); color: #fff; border-color: transparent; }

  .nav-dd-panel {
    position: absolute; top: calc(100% + 16px); left: 50%; transform: translateX(-50%) translateY(8px);
    min-width: 270px; padding: 0.5rem; border-radius: 16px;
    background: rgba(255,255,255,0.98); border: 1px solid rgb(228,223,214);
    backdrop-filter: blur(18px) saturate(160%); -webkit-backdrop-filter: blur(18px) saturate(160%);
    box-shadow: 0 20px 44px -16px rgba(30,35,45,0.24);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease, transform 0.25s ease; z-index: 60;
  }
  .nav-dd-panel::before { content: ""; position: absolute; left: 0; right: 0; top: -18px; height: 20px; }
  .nav-dd:hover .nav-dd-panel, .nav-dd:focus-within .nav-dd-panel { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav-dd:hover .nav-dd-chev { transform: rotate(180deg); }
  .nav-dd-chev { transition: transform 0.3s ease; }
  .nav-dd-item { display: block; padding: 0.62rem 0.85rem; border-radius: 10px; font-size: 0.92rem; font-weight: 500; color: rgba(23,37,64,0.78); transition: background 0.2s ease, color 0.2s ease; }
  .nav-dd-item:hover { background: rgb(var(--rgb-blue) / 0.08); color: rgb(var(--rgb-blue-ink)); }
  .nav-dd-item.active { color: rgb(var(--rgb-blue-ink)); background: rgb(var(--rgb-blue) / 0.06); font-weight: 600; }
</style>

<script>
  function isOpen() { const m = document.getElementById('mobile-menu'); return !!m && !m.classList.contains('hidden'); }
  function setOpen(open: boolean) {
    const menu = document.getElementById('mobile-menu');
    const toggle = document.getElementById('menu-toggle');
    const burger = toggle?.querySelector('.hamburger');
    if (!menu) return;
    menu.classList.toggle('hidden', !open);
    burger?.classList.toggle('open', open);
    toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle?.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    document.body.style.overflow = open ? 'hidden' : '';
  }
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', (e) => { e.stopPropagation(); setOpen(!isOpen()); });
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.body.style.overflow = '';
  });
  const w = window as any;
  if (!w.__havHeader) {
    w.__havHeader = true;
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen()) setOpen(false); });
    document.addEventListener('click', (e) => { const h = document.getElementById('site-header'); if (isOpen() && h && !h.contains(e.target as Node)) setOpen(false); });
    window.addEventListener('resize', () => { if (window.innerWidth >= 1024 && isOpen()) setOpen(false); });
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return; ticking = true;
      requestAnimationFrame(() => {
        const pill = document.getElementById('nav-pill');
        if (pill) {
          if (window.scrollY > 16) {
            pill.style.background = 'rgba(255,255,255,0.9)';
            pill.style.boxShadow = '0 1px 0 rgba(255,255,255,0.6) inset, 0 14px 40px -18px rgba(8,48,63,0.36)';
          } else {
            pill.style.background = 'rgba(250,249,246,0.68)';
            pill.style.boxShadow = '0 1px 0 rgba(255,255,255,0.55) inset, 0 10px 38px -18px rgba(8,48,63,0.3)';
          }
        }
        ticking = false;
      });
    }, { passive: true });
  }
</script>
